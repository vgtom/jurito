datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserPlan {
  FREE
  PRO
}

enum DocumentStatus {
  DRAFT
  SENT
  SIGNED
}

enum PartySigningStatus {
  NOT_SENT
  AWAITING_SIGNATURE
  COMPLETED
}

enum SignatureFieldType {
  SIGNATURE
  INITIALS
  DATE
  TEXT
  IMAGE
}

model User {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  email                     String?         @unique
  username                  String?         @unique
  isAdmin                   Boolean         @default(false)

  paymentProcessorUserId    String?         @unique
  lemonSqueezyCustomerPortalUrl String?     // You can delete this if you're not using Lemon Squeezy as your payments processor.
  subscriptionStatus        String?         // 'active', 'cancel_at_period_end', 'past_due', 'deleted'
  subscriptionPlan          String?         // 'hobby', 'pro'
  plan                      UserPlan        @default(FREE) // LemonSqueezy / feature gating
  datePaid                  DateTime?
  credits                   Int             @default(3)

  gptResponses              GptResponse[]
  contactFormMessages       ContactFormMessage[]
  tasks                     Task[]
  files                     File[]
  documents                 Document[]
  documentFolders           DocumentFolder[]
  signatureImages           SignatureImage[]
  userContacts              UserContact[]
}

/// User-defined folder for organizing document templates (default name: MyFolder).
model DocumentFolder {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  name      String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  documents Document[]

  @@unique([userId, name])
}

model Document {
  id              String           @id @default(uuid())
  createdAt       DateTime         @default(now())

  name            String
  status          DocumentStatus   @default(DRAFT)
  fileUrl         String

  /// When the template was first sent for signing (Submissions tab).
  sentAt          DateTime?

  /// If true, signing invites are emailed one party at a time in sortOrder; otherwise all at once.
  preserveSigningOrder Boolean @default(false)

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String

  folderId String
  folder   DocumentFolder @relation(fields: [folderId], references: [id], onDelete: Restrict)

  parties         DocumentParty[]
  signatureFields SignatureField[]
  appends         DocumentAppend[]
}

/// A signer / counterparty slot on a document (First party, Second party, …).
model DocumentParty {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())
  sortOrder  Int
  label      String

  /// Display name and email collected when sending for signing (may differ from `label`).
  signerName  String?
  signerEmail String?

  /// Opaque token for the public `/sign/:token` page; set when that party is invited.
  signingToken String? @unique

  signingStatus PartySigningStatus @default(NOT_SENT)

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  signatureFields SignatureField[]

  @@unique([documentId, sortOrder])
}

/// Saved signers for autocomplete when sending documents (per owner user).
model UserContact {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name  String
  email String

  @@unique([userId, email])
  @@index([userId])
}

/// Additional PDFs merged into a document template after the base `Document.fileUrl`.
model DocumentAppend {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())
  sortOrder  Int
  fileUrl    String

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, sortOrder])
}

model SignatureField {
  id         String             @id @default(uuid())

  type       SignatureFieldType
  xPos       Float
  yPos       Float
  pageNumber Int

  document   Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String

  documentParty   DocumentParty @relation(fields: [documentPartyId], references: [id], onDelete: Cascade)
  documentPartyId String
}

model SignatureImage {
  id       String @id @default(uuid())

  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String

  imageUrl String
}

model GptResponse {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  content                   String
}

model Task {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  description               String
  time                      String          @default("1")
  isDone                    Boolean         @default(false)
}

model File {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  name                      String
  type                      String
  s3Key                     String
}

model DailyStats {
  id                               Int             @id @default(autoincrement())
  date                             DateTime        @default(now()) @unique

  totalViews                       Int             @default(0)
  prevDayViewsChangePercent        String          @default("0")
  userCount                        Int             @default(0)
  paidUserCount                    Int             @default(0)
  userDelta                        Int             @default(0)
  paidUserDelta                    Int             @default(0)
  totalRevenue                     Float           @default(0)
  totalProfit                      Float           @default(0)

  sources                          PageViewSource[]
}

model PageViewSource {
  @@id([date, name])
  name                     String
  date                     DateTime        @default(now())

  dailyStats               DailyStats?     @relation(fields: [dailyStatsId], references: [id])
  dailyStatsId             Int?

  visitors                 Int
}

model Logs {
  id                       Int             @id @default(autoincrement())
  createdAt                DateTime        @default(now())

  message                  String
  level                    String
}

model ContactFormMessage {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  content                   String
  isRead                    Boolean         @default(false)
  repliedAt                 DateTime?
}
